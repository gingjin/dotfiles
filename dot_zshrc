# export PATH=$JAVA_HOME/bin:$PATH

# PERL_MM_OPT
export PERL_MM_OPT=$HOME/perl5
# PERL_MB_OPT
export PERL_MB_OPT=$HOME/perl5

# FZF
export FZF_DEFAULT_COMMAND="fd --hidden --exclude={.git,.idea,.vscode,.sass-cache,node_modules,build} --type f"
export FZF_DEFAULT_OPTS="--height 60% --layout=reverse --preview '(highlight -O ansi {} || bat {}) 2> /dev/null | head -500' --preview-window=down"

# Path to your oh-my-zsh installation.
export ZSH=/usr/share/oh-my-zsh
source $ZSH/oh-my-zsh.sh

# Plugins
autoload -U promptinit; promptinit
prompt spaceship
source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh

plugins=(archlinux cp gem git man node npm perl pip ruby yarn z)

# Alias
alias vi='nvim'
alias install='sudo pacman -S'
alias search="sudo pacman -Ss"
alias update='sudo pacman -Syyu'
alias remove='sudo pacman -R'
